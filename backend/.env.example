# ============================================================
# DataScrap Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
# ============================================================

# LinkedIn credentials (required for the LinkedIn scraper)
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password_here

# Google Maps Scraper Settings
GOOGLE_MAPS_HEADLESS=true
PROXY_LIST=  # Comma-separated list of proxies (e.g., http://user:pass@host:port,...)
ENABLE_EMAIL_EXTRACT=true
MASTER_DATASET_PATH=output/google_maps_master.csv
